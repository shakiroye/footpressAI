# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMB_DEPLOYMENT=text-embedding-3-small

# Azure AI Language
AZURE_AI_LANGUAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_AI_LANGUAGE_KEY=your_key_here

# Azure AI Vision
AZURE_AI_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_AI_VISION_KEY=your_key_here

# Azure Blob Storage
AZURE_STORAGE_CONN_STR=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;...
AZURE_STORAGE_CONTAINER=footpress-docs

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your_key_here
AZURE_SEARCH_INDEX=footpress-index

# Sécurité — clés API (format: user_id:api_key, séparées par virgule)
FOOTPRESS_API_KEYS=journaliste1:key-j1-footpress,journaliste2:key-j2-footpress,demo-key-footpress
